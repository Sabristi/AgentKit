# ── AgentKit — Server config ────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# ⚠️  Never commit .env — it contains your API key

# Your Anthropic API key (required)
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Absolute path to your Salesforce DX project (required)
# The server reads .agent and XML files from here
# and writes generated YAML specs to <SF_PROJECT_PATH>/specs/
SF_PROJECT_PATH=/Users/yourname/Projects/my-sfdx-project

# Default target org alias used in sf CLI commands (optional)
# Run: sf org list  — to see your available orgs
TARGET_ORG=my-dev-org

# Server port (optional, default: 3001)
PORT=3001
